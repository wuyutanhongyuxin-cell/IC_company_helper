# WaferCut MES — 环境变量模板
# 复制为 .env 后修改值，deploy.sh 会自动生成 SECRET_KEY
# 注意: systemd EnvironmentFile 不支持引号包裹值，值中勿用空格/引号

# Flask 应用入口
FLASK_APP=wsgi.py
FLASK_DEBUG=0

# Flask 配置类（生产环境必须用 ProductionConfig）
FLASK_CONFIG=config.ProductionConfig

# 安全密钥（deploy.sh 自动生成，勿手动填写弱密码）
SECRET_KEY=

# 默认管理员账号（首次 init-db 使用，之后可在 UI 中修改密码）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# 数据库路径（默认即可，一般无需修改）
# DATABASE_URL=sqlite:////opt/wafercut/instance/wafercut.db
